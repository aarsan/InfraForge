# InfraForge — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Or run the setup wizard:
#   .\scripts\setup.ps1

# ─────────────────────────────────────────────────────────
# Entra ID (Azure AD) Authentication
# Create an App Registration in Azure Portal → Entra ID → App Registrations
# API Permissions required: Microsoft Graph → User.Read (delegated)
# ─────────────────────────────────────────────────────────
ENTRA_CLIENT_ID=
ENTRA_TENANT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URI=http://localhost:8080/api/auth/callback

# ─────────────────────────────────────────────────────────
# Database — Azure SQL with Azure AD auth
# Format: Driver={ODBC Driver 18 for SQL Server};Server=tcp:<server>.database.windows.net,1433;Database=<db>;Encrypt=yes;TrustServerCertificate=no;Connection Timeout=30
# Requires: ODBC Driver 18 for SQL Server installed locally
#   Windows: https://learn.microsoft.com/en-us/sql/connect/odbc/download-odbc-driver-for-sql-server
#   macOS:   brew install msodbcsql18
#   Linux:   https://learn.microsoft.com/en-us/sql/connect/odbc/linux-mac/installing-the-microsoft-odbc-driver-for-sql-server
# ─────────────────────────────────────────────────────────
AZURE_SQL_CONNECTION_STRING=
AZURE_SUBSCRIPTION_ID=
# Used by SQL firewall auto-fix (auto-parsed from connection string if omitted)
AZURE_SQL_SERVER=
AZURE_RESOURCE_GROUP=InfraForge

# ─────────────────────────────────────────────────────────
# GitHub Integration (service-level — users don't need GitHub accounts)
# Create a PAT at https://github.com/settings/tokens with 'repo' scope
# ─────────────────────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_ORG=

# ─────────────────────────────────────────────────────────
# Copilot SDK
# ─────────────────────────────────────────────────────────
COPILOT_MODEL=gpt-4.1
COPILOT_LOG_LEVEL=warning

# ─────────────────────────────────────────────────────────
# Web Server
# ─────────────────────────────────────────────────────────
INFRAFORGE_WEB_HOST=0.0.0.0
INFRAFORGE_WEB_PORT=8080
INFRAFORGE_SESSION_SECRET=

# ─────────────────────────────────────────────────────────
# Output directory for generated files
# ─────────────────────────────────────────────────────────
INFRAFORGE_OUTPUT_DIR=./output

# ─────────────────────────────────────────────────────────
# Microsoft Fabric Integration (Optional — OneLake analytics sync)
# Leave blank to disable Fabric integration
# ─────────────────────────────────────────────────────────
FABRIC_WORKSPACE_ID=
FABRIC_ONELAKE_DFS_ENDPOINT=
FABRIC_LAKEHOUSE_NAME=

# ─────────────────────────────────────────────────────────
# Microsoft Work IQ (Optional — M365 organizational intelligence)
# Requires Node.js 18+. Run `npx -y @microsoft/workiq accept-eula` first.
# Set to false to disable.
# ─────────────────────────────────────────────────────────
WORKIQ_ENABLED=true
WORKIQ_TIMEOUT=90
